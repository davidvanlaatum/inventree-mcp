# InvenTree MCP packaged HTTP service configuration.
#
# Production HTTP mode is disabled until OAuth is implemented. Keep this service
# disabled or use development-only settings until the OAuth milestone lands.
INVENTREE_MCP_LISTEN=127.0.0.1:28686
INVENTREE_MCP_PATH=/mcp
INVENTREE_URL=https://inventory.example.test
INVENTREE_MCP_ENVIRONMENT=production
INVENTREE_MCP_LOG_LEVEL=info

# Development-only pre-OAuth config-validation settings. The current command
# skeleton exits after validation; do not enable the systemd service yet.
# INVENTREE_MCP_ENVIRONMENT=development
# INVENTREE_MCP_DEV_INCOMPLETE_OAUTH=true
